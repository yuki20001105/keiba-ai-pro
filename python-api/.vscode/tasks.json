{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start FastAPI",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["main.py"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "servers"
      }
    },
    {
      "label": "Start Next.js",
      "type": "shell",
      "command": "C:\\Program Files\\nodejs\\npm.cmd",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/..",
        "env": {
          "PATH": "C:\\Program Files\\nodejs;${env:PATH}"
        }
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "servers"
      }
    },
    {
      "label": "Start All Servers",
      "dependsOn": ["Start FastAPI", "Start Next.js"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}
