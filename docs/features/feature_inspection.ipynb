   ],
   "source": [
    "## 笏笏 Cell M1: 蛻・梵邨先棡 JSON 讒狗ｯ・+ 菫晏ｭ・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "import json, math\n",
    "\n",
    "def _to_py(v):\n",
    "    if isinstance(v, float) and (math.isnan(v) or math.isinf(v)): return None\n",
    "    if hasattr(v, \"item\"): return v.item()\n",
    "    return v\n",
    "\n",
    "# 笏笏 繧ｰ繝ｫ繝ｼ繝励・繝・ヴ繝ｳ繧ｰ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "_feat_to_grp = {_c: _gn for _gn, _gcs in _GMAP.items() for _c in _gcs}\n",
    "\n",
    "# 笏笏 迚ｹ蠕ｴ驥上＃縺ｨ縺ｮ邨ｱ蜷医ョ繝ｼ繧ｿ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "_fa_features = []\n",
    "for _, row in final_rank_df.iterrows():\n",
    "    c = row[\"feature\"]\n",
    "    _fa_features.append({\n",
    "        \"rank\":        _to_py(row[\"#\"]),\n",
    "        \"feature\":     c,\n",
    "        \"group\":       _feat_to_grp.get(c, \"竭ｪ縺昴・莉暴"),\n",
    "        \"tier\":        row[\"rank\"],\n",
    "        \"op_class\":    row[\"驕狗畑蛻・｡杤"],\n",
    "        \"total_score\": round(_to_py(row[\"total\"]) or 0, 4),\n",
    "        \"spearman\":    round(_to_py(row[\"spearman\"]) or 0, 4),\n",
    "        \"MI_norm\":     round(_to_py(row.get(\"MI_norm\", 0)) or 0, 3),\n",
    "        \"gain_norm\":   round(_to_py(row.get(\"gain_norm\", 0)) or 0, 4),\n",
    "        \"perm_imp\":    round(_to_py(row[\"perm_imp\"]) or 0, 4),\n",
    "        \"shap\":        round(_to_py(row.get(\"shap\", 0)) or 0, 4) if _shap_ok else None,\n",
    "        \"nan_rate\":    round(_to_py(row[\"nan_rate\"]) or 0, 3),\n",
    "        \"leak_risk\":   row[\"leak_risk\"],\n",
    "        \"vif\":         round(_to_py(row.get(\"VIF\", 1)) or 1, 1),\n",
    "    })\n",
    "\n",
    "# 笏笏 鬮倡嶌髢｢繝壹い (TOP 30) 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "_hc_list = [\n",
    "    {\"A\": r[\"A\"], \"B\": r[\"B\"], \"r\": round(_to_py(r[\"r\"]), 4)}\n",
    "    for _, r in high_corr_df.head(30).iterrows()\n",
