   "source": [
    "## 笏笏 Cell L6: 竭ｦ 譛邨りｩ穂ｾ｡ 窶・S/A/B/C 繝ｩ繝ｳ繧ｯ + 蠢・・/ 謗ｨ螂ｨ / 蜑企勁蛟呵｣・笏笏笏笏笏笏笏笏\n",
    "# 蜈ｨ蛻・梵繧ｹ繧ｳ繧｢繧堤ｵｱ蜷医＠縲∫ｫｶ鬥ｬ AI 螳溷漁驕狗畑隕ｳ轤ｹ縺ｧ繝ｩ繝ｳ繧ｯ莉倥￠縺吶ｋ\n",
    "\n",
    "from matplotlib.patches import Patch\n",
    "\n",
    "# 笏笏 蜷・せ繧ｳ繧｢繧堤ｵｱ蜷・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "def _s01(s): return (s - s.min()) / (s.max() - s.min() + 1e-12)\n",
    "\n",
    "_final = importance_df[[\"feature\", \"composite\", \"gain\", \"perm_imp\"]].copy()\n",
    "_final = _final.merge(univariate_df[[\"feature\",\"spearman\",\"spearman_abs\",\"MI_norm\"]], on=\"feature\", how=\"left\")\n",
    "_final = _final.merge(quality_df[[\"feature\",\"nan_rate\",\"leak_risk\",\"譁ｭ謐ｨ髮｢繧｢繧ｯ繧ｷ繝ｧ繝ｳ\"]], on=\"feature\", how=\"left\")\n",
    "_final = _final.merge(vif_df[[\"feature\",\"VIF\"]], on=\"feature\", how=\"left\")\n",
    "\n",
    "# 繧ｹ繧ｳ繧｢謌仙・ (0縲・)\n",
    "_final[\"s_model\"]  = _s01(_final[\"composite\"])\n",
    "_final[\"s_univ\"]   = (_final[\"spearman_abs\"].clip(0, 0.3) / 0.3)\n",
    "_final[\"s_mi\"]     = _final[\"MI_norm\"].fillna(0)\n",
    "_final[\"s_nan\"]    = 1 - _final[\"nan_rate\"].clip(0, 1)        # NaN 蟆代↑縺・= 鬮倥せ繧ｳ繧｢\n",
    "_final[\"s_leak\"]   = _final[\"leak_risk\"].map({\"HIGH\":0,\"MEDIUM\":0.5,\"LOW\":1.0}).fillna(1.0)\n",
    "_final[\"s_vif\"]    = (1 / (_final[\"VIF\"].clip(1, 50) / 50 + 1e-6)\n",
    "                      ).pipe(_s01).fillna(0.5)               # VIF 蟆上＆縺・= 鬮倥せ繧ｳ繧｢\n",
    "\n",
    "# 邱丞粋繧ｹ繧ｳ繧｢: 驥阪∩莉倥￠蟷ｳ蝮Ⅸn",
    "_final[\"total\"] = (\n",
    "    0.40 * _final[\"s_model\"] +\n",
    "    0.20 * _final[\"s_univ\"]  +\n",
    "    0.10 * _final[\"s_mi\"]    +\n",
    "    0.15 * _final[\"s_nan\"]   +\n",
    "    0.10 * _final[\"s_leak\"]  +\n",
    "    0.05 * _final[\"s_vif\"]\n",
    ").clip(0, 1)\n",
    "\n",
    "# 笏笏 S/A/B/C 繝ｩ繝ｳ繧ｯ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "def _rank(s):\n",
    "    if s >= 0.65: return \"S\"\n",
    "    if s >= 0.45: return \"A\"\n",
    "    if s >= 0.25: return \"B\"\n",
    "    return \"C\"\n",
    "\n",
    "_final[\"rank\"] = _final[\"total\"].apply(_rank)\n",
    "_final = _final.sort_values(\"total\", ascending=False).reset_index(drop=True)\n",
