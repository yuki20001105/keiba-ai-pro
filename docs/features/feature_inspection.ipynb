   "source": [
    "## 笏笏 Cell P_Notion: Notion 繧ｨ繧ｯ繧ｹ繝昴・繝・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "# LLM 縺檎函謌舌＠縺溘Ξ繝昴・繝医ｒ Notion 繝壹・繧ｸ縺ｨ縺励※菫晏ｭ倥☆繧欺n",
    "\n",
    "# 笏笏 險ｭ螳・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "NOTION_TOKEN   = \"YOUR_NOTION_TOKEN\"\n",
    "NOTION_PAGE_ID = \"https://www.notion.so/AI-37e2e86b510e804cbad3df2c0f322f68\"\n",
    "# 竊・URL 縺ｧ繧・UUID 縺ｧ繧ゅ◎縺ｮ縺ｾ縺ｾ雋ｼ縺｣縺ｦOK\n",
    "\n",
    "# 笏笏 URL 竊・UUID 螟画鋤 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "import re as _re_n\n",
    "def _extract_notion_uuid(raw: str) -> str:\n",
    "    _s = raw.strip().split(\"?\")[0].split(\"#\")[0]\n",
    "    if _re_n.fullmatch(r\"[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\", _s, _re_n.I):\n",
    "        return _s.lower()\n",
    "    _m = _re_n.search(r\"([0-9a-f]{32})$\", _s, _re_n.I)\n",
    "    if _m:\n",
    "        _h = _m.group(1).lower()\n",
    "        return f\"{_h[:8]}-{_h[8:12]}-{_h[12:16]}-{_h[16:20]}-{_h[20:]}\"\n",
    "    return _s\n",
    "\n",
    "_page_id = _extract_notion_uuid(NOTION_PAGE_ID)\n",
    "print(f\"Page ID (螟画鋤蠕・: {_page_id}\")\n",
    "\n",
    "# 笏笏 notion-client 繧､繝ｳ繧ｹ繝医・繝ｫ遒ｺ隱・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "import sys\n",
    "try:\n",
    "    from notion_client import Client as _NC\n",
    "except ImportError:\n",
    "    import subprocess\n",
    "    print(\"notion-client 繧偵う繝ｳ繧ｹ繝医・繝ｫ荳ｭ...\")\n",
    "    subprocess.run([sys.executable, \"-m\", \"pip\", \"install\", \"notion-client\", \"-q\"], check=True)\n",
    "    from notion_client import Client as _NC\n",
    "\n",
    "# 笏笏 rich_text 逕滓・ (螟ｪ蟄励・繧ｳ繝ｼ繝峨・繧､繝ｳ繝ｩ繧､繝ｳ繧ｳ繝ｼ繝牙ｯｾ蠢・ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "def _rt(text: str) -> list:\n",
    "    \"\"\"Markdown 縺ｮ **螟ｪ蟄・* 縺ｨ `繧ｳ繝ｼ繝荏 繧偵ヱ繝ｼ繧ｹ縺励※ rich_text 繝ｪ繧ｹ繝医ｒ霑斐☆\"\"\"\n",
    "    result = []\n",
    "    # **bold** 縺ｨ `code` 繧剃ｺ､莠偵↓繝代・繧ｹ\n",
    "    pattern = _re_n.compile(r\"(\\*\\*(.+?)\\*\\*|`(.+?)`)\")\n",
    "    pos = 0\n",
    "    for m in pattern.finditer(text):\n",
    "        # 蜑阪・繝励Ξ繝ｼ繝ｳ繝・く繧ｹ繝・n",
    "        if m.start() > pos:\n",
    "            plain = text[pos:m.start()][:2000]\n",
    "            if plain:\n",
    "                result.append({\"type\": \"text\", \"text\": {\"content\": plain}})\n",
    "        if m.group(0).startswith(\"**\"):\n",
    "            result.append({\"type\": \"text\", \"text\": {\"content\": m.group(2)[:200]},\n",
    "                           \"annotations\": {\"bold\": True}})\n",
    "        else:  # `code`\n",
    "            result.append({\"type\": \"text\", \"text\": {\"content\": m.group(3)[:200]},\n",
    "                           \"annotations\": {\"code\": True}})\n",
    "        pos = m.end()\n",
    "    # 谿九ｊ縺ｮ繝・く繧ｹ繝・n",
    "    tail = text[pos:][:2000]\n",
    "    if tail:\n",
    "        result.append({\"type\": \"text\", \"text\": {\"content\": tail}})\n",
    "    return result or [{\"type\": \"text\", \"text\": {\"content\": text[:2000]}}]\n",
    "\n",
    "# 笏笏 繧ｻ繧ｯ繧ｷ繝ｧ繝ｳ繧｢繧､繧ｳ繝ｳ繝槭ャ繝・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "_SECTION_ICONS = {\n",
    "    \"1\": \"醇\", \"2\": \"卵・十", \"3\": \"笞・十", \"4\": \"迫\",\n",
    "    \"5\": \"順\", \"6\": \"嶋\", \"7\": \"腸\", \"8\": \"庁\",\n",
    "}\n",
    "_SECTION_COLORS = {\n",
    "    \"1\": \"blue\", \"2\": \"red\", \"3\": \"orange\", \"4\": \"purple\",\n",
    "    \"5\": \"green\", \"6\": \"yellow\", \"7\": \"pink\", \"8\": \"gray\",\n",
    "}\n",
    "\n",
    "def _section_num(heading: str) -> str:\n",
    "    \"\"\"隕句・縺励ユ繧ｭ繧ｹ繝医°繧臥分蜿ｷ繧呈歓蜃ｺ ('1. ...' 竊・'1')\"\"\"\n",
    "    m = _re_n.match(r\"\\s*(\\d+)\", heading)\n",
    "    return m.group(1) if m else \"\"\n",
    "\n",
    "# 笏笏 Markdown 竊・Notion 繝悶Ο繝・け螟画鋤 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "def _md_to_blocks(md: str) -> list:\n",
    "    blocks     = []\n",
    "    tbl_rows   = []\n",
    "    in_table   = False\n",
    "    in_code    = False\n",
    "    code_lines = []\n",
    "    prev_was_h2 = False\n",
    "\n",
    "    def _flush_table():\n",
    "        if not tbl_rows: return\n",
    "        w = max(len(r) for r in tbl_rows)\n",
    "        children = []\n",
    "        for row in tbl_rows:\n",
    "            cells = [[{\"type\": \"text\", \"text\": {\"content\": c.strip()[:200]}}]\n",
    "                     for c in (row + [\"\"] * w)[:w]]\n",
    "            children.append({\n",
    "                \"object\": \"block\", \"type\": \"table_row\",\n",
    "                \"table_row\": {\"cells\": cells},\n",
    "            })\n",
    "        blocks.append({\n",
    "            \"object\": \"block\", \"type\": \"table\",\n",
    "            \"table\": {\"table_width\": w, \"has_column_header\": True,\n",
    "                      \"has_row_header\": False, \"children\": children},\n",
    "        })\n",
    "        tbl_rows.clear()\n",
    "\n",
    "    def _flush_code(lang=\"\"):\n",
    "        if not code_lines: return\n",
    "        blocks.append({\n",
    "            \"object\": \"block\", \"type\": \"code\",\n",
    "            \"code\": {\n",
    "                \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"\\n\".join(code_lines)[:2000]}}],\n",
    "                \"language\": lang or \"plain text\",\n",
    "            },\n",
    "        })\n",
    "        code_lines.clear()\n",
    "\n",
    "    for line in md.split(\"\\n\"):\n",
    "        # 繧ｳ繝ｼ繝峨ヵ繧ｧ繝ｳ繧ｹ蜃ｦ逅・n",
    "        if line.strip().startswith(\"```\"):\n",
    "            if in_code:\n",
    "                _flush_code()\n",
    "                in_code = False\n",
    "            else:\n",
    "                if in_table: _flush_table(); in_table = False\n",
    "                lang = line.strip()[3:].strip()\n",
    "                in_code = True\n",
    "            continue\n",
    "        if in_code:\n",
    "            code_lines.append(line)\n",
    "            continue\n",
    "\n",
    "        # 繝・・繝悶Ν陦圭n",
    "        if line.strip().startswith(\"|\") and \"|\" in line[1:]:\n",
    "            cols = [c.strip() for c in line.strip().strip(\"|\").split(\"|\")]\n",
    "            # 繧ｻ繝代Ξ繝ｼ繧ｿ陦・(|---|) 繧帝勁螟暴n",
    "            if not all(_re_n.fullmatch(r\"[:\\-\\s]+\", c) for c in cols):\n",
    "                tbl_rows.append(cols)\n",
    "            in_table = True\n",
    "            continue\n",
    "        if in_table:\n",
    "            _flush_table(); in_table = False\n",
    "\n",
    "        s = line.strip()\n",
    "\n",
    "        # 遨ｺ陦圭n",
    "        if not s:\n",
    "            continue\n",
    "\n",
    "        # H1\n",
    "        if line.startswith(\"# \") and not line.startswith(\"## \"):\n",
    "            heading_text = line[2:].strip()\n",
    "            blocks.append({\"object\":\"block\",\"type\":\"heading_1\",\n",
    "                            \"heading_1\":{\"rich_text\":_rt(heading_text)}})\n",
    "            prev_was_h2 = False\n",
    "\n",
    "        # H2 竊・divider + callout 縺ｧ隕九ｄ縺吶￥縺吶ｋ\n",
    "        elif line.startswith(\"## \"):\n",
    "            heading_text = line[3:].strip()\n",
    "            num = _section_num(heading_text)\n",
    "            icon = _SECTION_ICONS.get(num, \"東\")\n",
    "            color = _SECTION_COLORS.get(num, \"default\")\n",
    "            # 繧ｻ繧ｯ繧ｷ繝ｧ繝ｳ髢薙↓ divider\n",
    "            if prev_was_h2:\n",
    "                blocks.append({\"object\":\"block\",\"type\":\"divider\",\"divider\":{}})\n",
    "            blocks.append({\n",
    "                \"object\": \"block\", \"type\": \"heading_2\",\n",
    "                \"heading_2\": {\n",
    "                    \"rich_text\": _rt(f\"{icon}  {heading_text}\"),\n",
    "                    \"color\": f\"{color}_background\",\n",
    "                },\n",
    "            })\n",
    "            prev_was_h2 = True\n",
    "\n",
    "        # H3\n",
    "        elif line.startswith(\"### \"):\n",
    "            heading_text = line[4:].strip()\n",
    "            blocks.append({\"object\":\"block\",\"type\":\"heading_3\",\n",
    "                            \"heading_3\":{\"rich_text\":_rt(heading_text)}})\n",
    "            prev_was_h2 = False\n",
    "\n",
    "        # 蠑慕畑繝悶Ο繝・け\n",
    "        elif s.startswith(\"> \"):\n",
    "            blocks.append({\"object\":\"block\",\"type\":\"quote\",\n",
    "                            \"quote\":{\"rich_text\":_rt(s[2:])}})\n",
    "\n",
    "        # 邂・擅譖ｸ縺構n",
    "        elif s.startswith(\"- \") or s.startswith(\"* \"):\n",
    "            blocks.append({\"object\":\"block\",\"type\":\"bulleted_list_item\",\n",
    "                            \"bulleted_list_item\":{\"rich_text\":_rt(s[2:])}})\n",
    "\n",
    "        # 逡ｪ蜿ｷ莉倥″繝ｪ繧ｹ繝・n",
    "        elif len(s) > 2 and s[0].isdigit() and s[1] in \".)\" and s[2] == \" \":\n",
    "            blocks.append({\"object\":\"block\",\"type\":\"numbered_list_item\",\n",
    "                            \"numbered_list_item\":{\"rich_text\":_rt(s[3:])}})\n",
    "\n",
    "        # 蛹ｺ蛻・ｊ邱喀n",
    "        elif s in (\"---\",\"***\",\"___\"):\n",
    "            blocks.append({\"object\":\"block\",\"type\":\"divider\",\"divider\":{}})\n",
    "\n",
    "        # 谿ｵ關ｽ\n",
    "        else:\n",
    "            blocks.append({\"object\":\"block\",\"type\":\"paragraph\",\n",
    "                            \"paragraph\":{\"rich_text\":_rt(s)}})\n",
    "\n",
    "    _flush_table()\n",
    "    _flush_code()\n",
    "    return blocks\n",
    "\n",
    "# 笏笏 螳溯｡・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "if not NOTION_TOKEN or not NOTION_PAGE_ID:\n",
    "    print(\"笞 NOTION_TOKEN 縺ｨ NOTION_PAGE_ID 縺梧悴險ｭ螳壹〒縺兔")\n",
    "\n",
    "elif \"_report_text\" not in dir() or not _report_text:\n",
    "    print(\"笞 LLM 繝ｬ繝昴・繝医′譛ｪ逕滓・縺ｧ縺吶ょ・縺ｫ Cell M3 繧貞ｮ溯｡後＠縺ｦ縺上□縺輔＞\")\n",
    "\n",
    "else:\n",
    "    print(\"Notion 縺ｫ謗･邯壻ｸｭ...\")\n",
    "    try:\n",
    "        _nc  = _NC(auth=NOTION_TOKEN)\n",
    "        _me  = _nc.users.me()\n",
    "        print(f\"笨・隱崎ｨｼ謌仙粥  ({_me.get('name', 'unknown')})\\n\")\n",
    "\n",
    "        _title  = f\"迚ｹ蠕ｴ驥丞・譫舌Ξ繝昴・繝・{pd.Timestamp.now().strftime('%Y-%m-%d %H:%M')}  [{LLM_MODEL}]\"\n",
    "        _blocks = _md_to_blocks(_report_text)\n",
    "\n",
    "        # 笏笏 繝壹・繧ｸ蜀帝ｭ縺ｫ ROI 繧ｵ繝槭Μ繝ｼ callout 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "        _rs = feature_analysis_json.get(\"roi_stats\", {})\n",
    "        if _rs and \"roi_top1_pct\" in _rs:\n",
    "            _n_races_str = f\"{int(_rs['n_races']):,}\" if _rs.get('n_races') else \"?\"\n",
    "            _roi_line = (\n",
    "                f\"蜊伜享逧・ｸｭ: {float(_rs['top1_win_rate'])*100:.1f}%縲\"\n",
    "                f\"隍・享逧・ｸｭ: {float(_rs['top1_show_rate'])*100:.1f}%縲\"\n",
    "                f\"Top3蛹・性: {float(_rs['top3_hit_rate'])*100:.1f}%縲\"\n",
    "                f\"ROI: {float(_rs['roi_top1_pct']):+.1f}%縲\"\n",
    "                f\"繝・せ繝医Ξ繝ｼ繧ｹ謨ｰ: {_n_races_str}莉ｶ\"\n",
    "            )\n",
    "            _blocks.insert(0, {\n",
    "                \"object\": \"block\", \"type\": \"callout\",\n",
    "                \"callout\": {\n",
    "                    \"rich_text\": [{\"type\":\"text\",\"text\":{\"content\":_roi_line}}],\n",
    "                    \"icon\": {\"type\":\"emoji\",\"emoji\":\"投\"},\n",
    "                    \"color\": \"blue_background\",\n",
    "                },\n",
    "            })\n",
    "            # 繝｡繧ｿ諠・ｱ callout\n",
    "            _meta = feature_analysis_json.get(\"meta\", {})\n",
    "            _n_train = _meta.get('n_train_rows')\n",
    "            _n_train_str = f\"{int(_n_train):,}\" if isinstance(_n_train, (int, float)) else str(_n_train or '?')\n",
    "            _meta_line = (\n",
    "                f\"繝｢繝・Ν: {LLM_MODEL}縲\"\n",
    "                f\"迚ｹ蠕ｴ驥乗焚: {_meta.get('n_features','?')}縲\"\n",
    "                f\"蟄ｦ鄙定｡梧焚: {_n_train_str}縲\"\n",
    "                f\"Spearman: {_meta.get('spearman','?')}\"\n",
    "            )\n",
    "            _blocks.insert(1, {\n",
    "                \"object\": \"block\", \"type\": \"callout\",\n",
    "                \"callout\": {\n",
    "                    \"rich_text\": [{\"type\":\"text\",\"text\":{\"content\":_meta_line}}],\n",
    "                    \"icon\": {\"type\":\"emoji\",\"emoji\":\"､暴"},\n",
    "                    \"color\": \"gray_background\",\n",
    "                },\n",
    "            })\n",
    "\n",
    "        # 笏笏 繝壹・繧ｸ菴懈・ (100繝悶Ο繝・け縺壹▽) 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "        _CHUNK = 100\n",
    "        _new_page = _nc.pages.create(\n",
    "            parent={\"page_id\": _page_id},\n",
    "            properties={\"title\": {\"title\": [{\"type\":\"text\",\"text\":{\"content\":_title}}]}},\n",
    "            children=_blocks[:_CHUNK],\n",
    "        )\n",
    "        _pid = _new_page[\"id\"]\n",
    "\n",
    "        for _i in range(_CHUNK, len(_blocks), _CHUNK):\n",
    "            _nc.blocks.children.append(block_id=_pid, children=_blocks[_i:_i+_CHUNK])\n",
    "\n",
    "        _notion_url = f\"https://notion.so/{_pid.replace('-','')}\"\n",
    "        print(f\"笨・繝壹・繧ｸ菴懈・螳御ｺ・ ({len(_blocks)} 繝悶Ο繝・け)\")\n",
    "        print(f\"  繧ｿ繧､繝医Ν: {_title}\")\n",
    "        print(f\"  URL: {_notion_url}\")\n",
    "\n",
    "    except Exception as _ne:\n",
    "        print(f\"笶・Notion 繧ｨ繝ｩ繝ｼ: {_ne}\")"
   ]
  },
