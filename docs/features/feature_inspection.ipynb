    "    _df_pre_nb, _opt_nb, _cat_nb = prepare_for_lightgbm_ultimate(\n",
    "        df.copy(), target_col=TRAIN_TARGET, is_training=True,\n",
    "    )\n",
    "    print(f\"  蜀榊ｮ溯｡悟ｾ・ {_df_pre_nb.shape[1]} 蛻・ cat: {len(_cat_nb)}\")\n",
    "else:\n",
    "    _df_pre_nb, _cat_nb = df_pre, cat_features\n",
    "    print(f\"Cell 7 縺ｮ蜑榊・逅・ｵ先棡繧貞・蛻ｩ逕ｨ  ({_df_pre_nb.shape[1]} 蛻・ cat: {len(_cat_nb)})\")\n",
    "\n",
    "# 笏笏 繧ｿ繝ｼ繧ｲ繝・ヨ逕滓・ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "y_nb = _make_target(df, TRAIN_TARGET)\n",
    "\n",
    "# speed_deviation 縺ｮ蝣ｴ蜷医・ NaN 陦鯉ｼ域凾險域ｬ謳埼ｦｬ・峨ｒ髯､螟暴n",
    "if _is_regression:\n",
    "    _valid_mask = y_nb.notna()\n",
    "    y_nb       = y_nb[_valid_mask]\n",
    "    _df_pre_nb = _df_pre_nb.loc[_valid_mask]\n",
    "    print(f\"NaN髯､螟門ｾ・ {_valid_mask.sum():,}陦・(髯､螟・ {(~_valid_mask).sum():,}陦・\")\n",
