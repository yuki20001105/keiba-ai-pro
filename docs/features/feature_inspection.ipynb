   "source": [
    "## 笏笏 Cell I: 譁ｭ謐ｨ髮｢繧ｷ繝溘Η繝ｬ繝ｼ繧ｷ繝ｧ繝ｳ險ｭ螳・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "\n",
    "# 笏笏 竭 蜑企勁縺吶ｋ繧｢繧ｯ繧ｷ繝ｧ繝ｳ繧ｫ繝・ざ繝ｪ・・eport_df 縺ｮ縲梧耳螂ｨ繧｢繧ｯ繧ｷ繝ｧ繝ｳ縲榊・縺ｮ蛟､・俄楳笏\n",
    "# 荳玖ｨ倥°繧牙炎髯､縺励◆縺・き繝・ざ繝ｪ繧偵Μ繧ｹ繝医↓蜈･繧後ｋ・磯Κ蛻・ｸ閾ｴ・噂n",
    "PRUNE_ACTION_PREFIXES = [\n",
    "    \"蜑企勁謗ｨ螂ｨ\",          # lap_* / holding_* / training_* 縺ｪ縺ｩ鬮朗aN蛻予n",
    "    # \"蜀阪せ繧ｯ繝ｬ繧､繝励〒謾ｹ蝟Ы",  # sf_* / holding_just_* 縺ｪ縺ｩ・域悴蜿朱寔縺縺悟ｭ伜惠縺吶ｋ・噂n",
    "    # \"蜑榊・逅・ 譛鬆ｻ蛟､陬懷ｮ・or 蜑企勁\",  # corner_* / running_style_*\n",
    "]\n",
    "\n",
    "# 笏笏 竭｡ 謇句虚縺ｧ霑ｽ蜉蜑企勁縺吶ｋ蛻怜錐・・eport_df 縺ｫ縺ｪ縺・・縺ｧ繧ょ庄・俄楳笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "PRUNE_EXTRA_COLS: list[str] = [\n",
    "    # 萓・ \"horse_weight_change\",\n",
    "]\n",
    "\n",
    "# 笏笏 竭｢ 繧ｫ繝・ざ繝ｪ蜑企勁蟇ｾ雎｡縺ｧ繧ょｼｷ蛻ｶ逧・↓谿九☆蛻怜錐 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "PRUNE_KEEP_COLS: list[str] = [\n",
    "    # 萓・ \"holding_just_speed\",  # 菫晄戟縺励◆縺・・\n",
    "]\n",
    "\n",
    "# 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "# 蜑企勁蟇ｾ雎｡蛻励ｒ report_df 縺九ｉ閾ｪ蜍募庶髮・n",
    "_prune_by_action = set()\n",
    "for _prefix in PRUNE_ACTION_PREFIXES:\n",
    "    _matched = report_df[report_df[\"謗ｨ螂ｨ繧｢繧ｯ繧ｷ繝ｧ繝ｳ\"].str.startswith(_prefix)][\"column\"].tolist()\n",
    "    _prune_by_action.update(_matched)\n",
    "\n",
    "# 謇句虚霑ｽ蜉繝ｻ謇句虚髯､螟悶ｒ驕ｩ逕ｨ\n",
    "_prune_cols_all = (\n",
    "    (_prune_by_action | set(PRUNE_EXTRA_COLS)) - set(PRUNE_KEEP_COLS)\n",
    ")\n",
    "\n",
    "# 迴ｾ蝨ｨ縺ｮ蟄ｦ鄙堤音蠕ｴ驥擾ｼ・_train_nb・峨・縺・■螳滄圀縺ｫ蟄伜惠縺吶ｋ繧ゅ・縺ｮ縺ｿ蟇ｾ雎｡\n",
    "_prune_in_model     = sorted(_prune_cols_all & set(_feature_cols_nb))\n",
    "_prune_not_in_model = sorted(_prune_cols_all - set(_feature_cols_nb))\n",
    "_pruned_feature_cols = [c for c in _feature_cols_nb if c not in _prune_cols_all]\n",
    "\n",
    "# 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "print(f\"{'='*60}\")\n",
    "print(f\"縲先妙謐ｨ髮｢繧ｷ繝溘Η繝ｬ繝ｼ繧ｷ繝ｧ繝ｳ險ｭ螳壹曾")\n",
    "print(f\"{'='*60}\")\n",
    "print(f\"蜑企勁繧｢繧ｯ繧ｷ繝ｧ繝ｳ: {PRUNE_ACTION_PREFIXES}\")\n",
    "print()\n",
    "print(f\"  蜑企勁蟇ｾ雎｡・医Δ繝・Ν蜈･蜉帛・・・ {len(_prune_in_model):3d} 蛻予")\n",
    "print(f\"  蜑企勁蟇ｾ雎｡・医☆縺ｧ縺ｫ髯､螟厄ｼ・ : {len(_prune_not_in_model):3d} 蛻・ (蜿り・\")\n",
    "print(f\"  謇句虚霑ｽ蜉蜑企勁           : {len(PRUNE_EXTRA_COLS):3d} 蛻予")\n",
    "print(f\"  謇句虚菫晄戟               : {len(PRUNE_KEEP_COLS):3d} 蛻予")\n",
    "print()\n",
    "print(f\"  蜑企勁蜑・迚ｹ蠕ｴ驥乗焚: {len(_feature_cols_nb)}\")\n",
    "print(f\"  蜑企勁蠕・迚ｹ蠕ｴ驥乗焚: {len(_pruned_feature_cols)}\")\n",
    "print(f\"  蜑頑ｸ帶焚        : {len(_feature_cols_nb) - len(_pruned_feature_cols)}\")\n",
    "print()\n",
    "if _prune_in_model:\n",
    "    print(f\"縲仙炎髯､縺輔ｌ繧句・・医Δ繝・Ν蜈･蜉幢ｼ峨曾")\n",
    "    for c in _prune_in_model:\n",
    "        _nr = report_df.loc[report_df[\"column\"] == c, \"nan_%_before\"].values\n",
    "        _nr_str = f\"NaN={_nr[0]:.0f}%\" if len(_nr) else \"\"\n",
    "        _act = report_df.loc[report_df[\"column\"] == c, \"謗ｨ螂ｨ繧｢繧ｯ繧ｷ繝ｧ繝ｳ\"].values\n",
    "        _act_str = _act[0].replace(\"\\n\", \" \") if len(_act) else \"\"\n",
    "        print(f\"  {c:45s}  {_nr_str:9s}  {_act_str}\")"
   ]
