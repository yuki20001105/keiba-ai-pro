    "\n",
    "# 笏笏 繧ｰ繝ｫ繝ｼ繝励し繝槭Μ繝ｼ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "_gain_total = group_df[\"Gain蜷郁ｨ・"].sum() or 1\n",
    "_grp_list = []\n",
    "for _, r in group_df.iterrows():\n",
    "    _grp_list.append({\n",
