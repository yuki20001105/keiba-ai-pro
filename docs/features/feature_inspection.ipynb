    "## 笏笏 Cell M3: 繝ｬ繝昴・繝育函謌撰ｼ・en_feature_report.py 螳溯｡・+ LLM 邱乗峡繧ｳ繝｡繝ｳ繝茨ｼ俄楳笏\n",
    "# docs/reports/gen_feature_report.py 縺ｧ繝・・繝悶Ν繧・Python 逕滓・縺励―n",
    "# LLM 縺ｯ遏ｭ縺・ｷ乗峡繧ｳ繝｡繝ｳ繝医・縺ｿ諡・ｽ薙☆繧九・n",
    "#\n",
    "# 迚ｹ蠕ｴ驥上・隱ｬ譏弱・ docs/reports/feature_descriptions.yaml 縺ｧ邂｡逅・・n",
    "# 譁ｰ縺励＞迚ｹ蠕ｴ驥上ｒ霑ｽ蜉縺励◆繧・YAML 縺ｫ荳陦瑚ｿｽ險倥☆繧九□縺代〒繝ｬ繝昴・繝医↓蜿肴丐縺輔ｌ縺ｾ縺吶・n",
    "\n",
    "import subprocess, sys, time, re as _re, requests\n",
    "from IPython.display import Markdown, display as _disp\n",
    "\n",
    "_t_start = time.time()\n",
    "\n",
    "# 笏笏 1. Python 繧ｹ繧ｯ繝ｪ繝励ヨ縺ｧ繝ｬ繝昴・繝育函謌・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "_script = ROOT / \"docs\" / \"reports\" / \"gen_feature_report.py\"\n",
    "_result = subprocess.run([sys.executable, str(_script)],\n",
    "                         capture_output=True, text=True, encoding=\"utf-8\")\n",
    "print(_result.stdout.strip())\n",
    "if _result.returncode != 0:\n",
    "    print(\"ERROR: gen_feature_report.py 螟ｱ謨予")\n",
    "    print(_result.stderr)\n",
    "    raise RuntimeError(\"gen_feature_report.py failed\")\n",
    "\n",
    "# 笏笏 2. 逕滓・縺輔ｌ縺溘ヵ繧｡繧､繝ｫ繧定ｪｭ縺ｿ霎ｼ縺ｿ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "_out_path_md = ROOT / \"docs\" / \"reports\" / \"feature_llm_report.md\"\n",
    "_report_text = _out_path_md.read_text(encoding=\"utf-8\")\n",
    "print(f\"  隱ｭ縺ｿ霎ｼ縺ｿ: {len(_report_text):,} 譁・ｭ予")\n",
    "\n",
    "# 笏笏 3. LLM 邱乗峡繧ｳ繝｡繝ｳ繝茨ｼ医が繝励す繝ｧ繝ｳ・・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "def _is_mostly_english(text, threshold=0.55):\n",
    "    ascii_cnt = sum(1 for c in text if ord(c) < 128 and c.isprintable())\n",
    "    return ascii_cnt / max(len(text), 1) > threshold\n",
    "\n",
    "def _first_japanese_para(text):\n",
    "    for i, line in enumerate(text.split(\"\\n\")):\n",
    "        s = line.strip()\n",
    "        if s.startswith(\"#\") or _re.search(r\"[\\u3040-\\u9FFF]\", s) or \\\n",
    "                (s.startswith(\"-\") and _re.search(r\"[\\u3040-\\u9FFF]\", s)):\n",
    "            return \"\\n\".join(text.split(\"\\n\")[i:]).strip()\n",
    "    return text.strip()\n",
    "\n",
    "if LLM_BACKEND != \"print\":\n",
    "    print(f\"LLM ({LLM_MODEL}) 縺ｧ邱乗峡繧ｳ繝｡繝ｳ繝育函謌蝉ｸｭ窶ｦ\")\n",
    "    try:\n",
    "        _fa   = feature_analysis_json\n",
    "        _rs   = _fa.get(\"roi_stats\", {})\n",
    "        _meta = _fa.get(\"meta\", {})\n",
    "        _feats = _fa.get(\"features\", [])\n",
    "        _corrs = _fa.get(\"high_corr_pairs\", [])\n",
    "        _leak_feats = [f for f in _feats if f.get(\"leak_risk\",\"\") in (\"HIGH\",\"MEDIUM\")]\n",
    "        _del_feats  = [f for f in _feats if f.get(\"tier\") in (\"C\",\"D\")]\n",
    "\n",
    "        _sys_cmt = \"/no_think\\n遶ｶ鬥ｬAI縺ｮ迚ｹ蠕ｴ驥乗隼蝟・さ繝ｳ繧ｵ繝ｫ繧ｿ繝ｳ繝医よ律譛ｬ隱槭〒遏ｭ縺乗橿陦鍋噪縺ｪ繧｢繝峨ヰ繧､繧ｹ繧偵☆繧九・"\n",
    "        _usr_cmt = (\n",
    "            f\"/no_think\\n\\n莉･荳九・繝｢繝・Ν謖・ｨ吶ｒ隕九※謾ｹ蝟・・繧､繝ｳ繝医ｒ邂・擅譖ｸ縺・縲・轤ｹ縺ｧ霑ｰ縺ｹ縺ｦ縺上□縺輔＞・域律譛ｬ隱槭・縺ｿ縲∬｡ｨ荳崎ｦ・ｼ峨・\n\\n\"\n",
    "            f\"- Spearman逶ｸ髢｢: {_meta.get('spearman','?')}\\n\"\n",
    "            f\"- 迚ｹ蠕ｴ驥乗焚: {_meta.get('n_features','?')}\\n\"\n",
    "            f\"- ROI(逅・ｫ門腰蜍・: {_rs.get('roi_top1_pct','?')}%\\n\"\n",
    "            f\"- 蜑企勁蛟呵｣懃音蠕ｴ驥・ {len(_del_feats)}莉ｶ\\n\"\n",
    "            f\"- 鬮倡嶌髢｢繝壹い: {len(_corrs)}莉ｶ\\n\"\n",
    "            f\"- 繝ｪ繝ｼ繧ｯ逍第ヱ: {len(_leak_feats)}莉ｶ\\n\"\n",
    "        )\n",
    "        if LLM_BACKEND == \"ollama\":\n",
    "            _cmt_raw = requests.post(\n",
    "                \"http://localhost:11434/api/chat\",\n",
    "                json={\"model\": LLM_MODEL, \"stream\": False, \"think\": False,\n",
    "                      \"options\": {\"temperature\": 0.1, \"num_predict\": 1024},\n",
    "                      \"messages\": [{\"role\":\"system\",\"content\":_sys_cmt},\n",
    "                                   {\"role\":\"user\",\"content\":_usr_cmt}]},\n",
    "                timeout=120,\n",
    "            ).json()[\"message\"].get(\"content\",\"\").strip()\n",
    "        else:\n",
    "            _cmt_raw = requests.post(\n",
    "                f\"{LLM_API_BASE.rstrip('/')}/chat/completions\",\n",
    "                headers={\"Authorization\": f\"Bearer {LLM_API_KEY}\",\"Content-Type\":\"application/json\"},\n",
    "                json={\"model\":LLM_MODEL,\"temperature\":0.1,\"max_tokens\":1024,\n",
    "                      \"messages\":[{\"role\":\"system\",\"content\":_sys_cmt},{\"role\":\"user\",\"content\":_usr_cmt}]},\n",
    "                timeout=120,\n",
    "            ).json()[\"choices\"][0][\"message\"][\"content\"]\n",
    "\n",
    "        _cmt = _first_japanese_para(_cmt_raw)\n",
    "        if _cmt and not _is_mostly_english(_cmt):\n",
    "            _report_text += f\"\\n\\n---\\n\\n## 剥 邱乗峡繧ｳ繝｡繝ｳ繝茨ｼ・LLM_MODEL}・噂\n\\n{_cmt}\"\n",
    "            _out_path_md.write_text(_report_text, encoding=\"utf-8\")\n",
    "            print(f\"  笨・繧ｳ繝｡繝ｳ繝郁ｿｽ蜉繝ｻ荳頑嶌縺堺ｿ晏ｭ・ {len(_cmt)} 譁・ｭ予")\n",
    "        else:\n",
    "            print(f\"  笞 繧ｳ繝｡繝ｳ繝医′闍ｱ隱樔ｸｻ菴薙・縺溘ａ繧ｹ繧ｭ繝・・\")\n",
    "    except Exception as _ce:\n",
    "        print(f\"  笞 LLM 繧ｳ繝｡繝ｳ繝亥叙蠕怜､ｱ謨・(繧ｹ繧ｭ繝・・): {_ce}\")\n",
    "\n",
    "# 笏笏 4. 陦ｨ遉ｺ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "_elapsed = time.time() - _t_start\n",
    "print(f\"\\n笨・螳御ｺ・({_elapsed:.1f}s) | {len(_report_text):,} 譁・ｭ・| {_out_path_md.name}\")\n",
    "_disp(Markdown(f\"---\\n## 投 迚ｹ蠕ｴ驥丞・譫舌Ξ繝昴・繝・\n\\n{_report_text}\"))"
   ]
