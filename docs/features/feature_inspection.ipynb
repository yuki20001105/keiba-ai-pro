    "axes_j[2].axis(\"off\")\n",
    "_summary_text = [\n",
    "    [\"鬆・岼\",           \"蜑企勁蜑構",                   \"蜑企勁蠕圭"],\n",
    "    [\"迚ｹ蠕ｴ驥乗焚\",       str(len(_feature_cols_nb)), str(len(_pruned_feature_cols))],\n",
