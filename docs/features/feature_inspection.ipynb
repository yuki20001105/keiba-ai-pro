   "source": [
    "## 笏笏 繧ｻ繝ｫ 2: DB 隱ｭ縺ｿ霎ｼ縺ｿ + 譛滄俣繝輔ぅ繝ｫ繧ｿ + 迚ｹ蠕ｴ驥冗函謌・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "from keiba_ai.db_ultimate_loader import load_ultimate_training_frame\n",
    "from keiba_ai.feature_engineering import add_derived_features\n",
    "\n",
    "def _to_yyyymmdd(s: str) -> str:\n",
    "    \"\"\"'YYYY-MM' / 'YYYY-MM-DD' / 'YYYYMMDD' 繧・'YYYYMMDD' 縺ｫ豁｣隕丞喧\"\"\"\n",
    "    s = s.strip().replace(\"/\", \"-\")\n",
    "    parts = s.split(\"-\")\n",
    "    if len(parts) == 2:   # YYYY-MM\n",
    "        return parts[0] + parts[1].zfill(2) + \"01\"\n",
    "    if len(parts) == 3:   # YYYY-MM-DD\n",
    "        return parts[0] + parts[1].zfill(2) + parts[2].zfill(2)\n",
    "    return s              # YYYYMMDD 縺昴・縺ｾ縺ｾ\n",
    "\n",
    "print(\"DB繝ｭ繝ｼ繝我ｸｭ...\")\n",
    "df_raw = load_ultimate_training_frame(DB_PATH)\n",
    "print(f\"raw繝輔Ξ繝ｼ繝・亥・譛滄俣・・ {len(df_raw):,}陦・ﾃ・{len(df_raw.columns)}蛻予")\n",
    "\n",
    "# 笏笏 譛滄俣繝輔ぅ繝ｫ繧ｿ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "if DATE_START or DATE_END:\n",
    "    # race_id 縺ｮ蜈磯ｭ 8 譯・= YYYYMMDD 縺ｧ譌･莉伜愛螳夲ｼ・ace_date 繧医ｊ遒ｺ螳滂ｼ噂n",
    "    race_dates = df_raw[\"race_id\"].astype(str).str[:8]\n",
    "    mask = pd.Series(True, index=df_raw.index)\n",
    "    if DATE_START:\n",
    "        mask &= race_dates >= _to_yyyymmdd(DATE_START)\n",
    "    if DATE_END:\n",
    "        _end_raw = _to_yyyymmdd(DATE_END)\n",
    "        # YYYY-MM 謖・ｮ壹・蝣ｴ蜷医・譛域忰縺ｾ縺ｧ蜷ｫ繧√ｋ・育ｿ梧怦蛻晄律 \"譛ｪ貅\" 縺ｫ螟画鋤・噂n",
    "        if _end_raw[6:] == \"01\" and len(DATE_END.replace(\"/\", \"-\").split(\"-\")) == 2:\n",
    "            from datetime import date as _date\n",
    "            y, m = int(_end_raw[:4]), int(_end_raw[4:6])\n",
    "            _next = _date(y + (m // 12), (m % 12) + 1, 1) if m < 12 else _date(y + 1, 1, 1)\n",
    "            _end_raw = _next.strftime(\"%Y%m%d\")\n",
    "        mask &= race_dates < _end_raw\n",
    "    df_raw = df_raw[mask].copy()\n",
    "    _date_range = f\"{DATE_START or '蜈磯ｭ'} 縲・{DATE_END or '譛ｫ蟆ｾ'}\"\n",
    "    print(f\"譛滄俣繝輔ぅ繝ｫ繧ｿ驕ｩ逕ｨ蠕・ {len(df_raw):,}陦・ ({_date_range})\")\n",
    "    print(f\"  譛蜿､ race_id: {df_raw['race_id'].min()}  譛譁ｰ race_id: {df_raw['race_id'].max()}\")\n",
    "\n",
    "print(\"\\n迚ｹ蠕ｴ驥冗函謌蝉ｸｭ・・dd_derived_features・・..\")\n",
    "df = add_derived_features(df_raw)\n",
    "print(f\"螳梧・繝輔Ξ繝ｼ繝: {len(df):,}陦・ﾃ・{len(df.columns)}蛻予")"
   ]
