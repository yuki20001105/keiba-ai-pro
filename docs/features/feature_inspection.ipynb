   "source": [
    "## 笏笏 Cell L2: 竭｡ 蜊伜､蛾㍼蛻・梵 (Spearman 逶ｸ髢｢ + Mutual Information) 笏笏笏笏笏笏笏笏笏\n",
    "from scipy.stats import spearmanr as _scipy_spearmanr\n",
    "from sklearn.feature_selection import mutual_info_regression\n",
    "\n",
    "# 繧ｵ繝ｳ繝励Μ繝ｳ繧ｰ (MI 縺ｯ險育ｮ励さ繧ｹ繝亥､ｧ 竊・20K 陦・\n",
    "_n_l2    = min(20_000, len(X_nb))\n",
    "_l2_idx  = X_nb.sample(n=_n_l2, random_state=42).index\n",
    "_Xl2     = X_nb.loc[_l2_idx, _feature_cols_nb].copy()\n",
    "_yl2     = y_nb.loc[_l2_idx].values\n",
    "\n",
    "# 笏笏 Spearman 逶ｸ髢｢ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "print(f\"Spearman 險育ｮ嶺ｸｭ ({len(_feature_cols_nb)} 蛻・ﾃ・{_n_l2:,} 陦・...\")\n",
    "_sp_dict = {}\n",
    "for c in _feature_cols_nb:\n",
    "    _col = _Xl2[c].fillna(_Xl2[c].median())\n",
    "    with warnings.catch_warnings():\n",
    "        warnings.simplefilter(\"ignore\")\n",
    "        _r, _ = _scipy_spearmanr(_col.values, _yl2)\n",
    "    _sp_dict[c] = float(_r) if not np.isnan(_r) else 0.0\n",
    "_sp_s = pd.Series(_sp_dict, name=\"spearman\")\n",
    "\n",
    "# 笏笏 Mutual Information 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "print(\"Mutual Information 險育ｮ嶺ｸｭ...\")\n",
    "_Xl2_filled = _Xl2.fillna(_Xl2.median())\n",
    "_mi_arr = mutual_info_regression(_Xl2_filled.values, _yl2, random_state=42, n_neighbors=5)\n",
    "_mi_s   = pd.Series(dict(zip(_feature_cols_nb, _mi_arr)), name=\"MI\")\n",
    "\n",
    "# 笏笏 univariate_df 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "univariate_df = pd.DataFrame({\n",
    "    \"spearman\":     _sp_s,\n",
    "    \"spearman_abs\": _sp_s.abs(),\n",
    "    \"MI\":           _mi_s,\n",
    "    \"MI_norm\":      _mi_s / _mi_s.max() if _mi_s.max() > 0 else _mi_s,\n",
    "}).reset_index().rename(columns={\"index\": \"feature\"})\n",
    "univariate_df = univariate_df.sort_values(\"spearman_abs\", ascending=False).reset_index(drop=True)\n",
    "\n",
    "# 笏笏 蜿ｯ隕門喧 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "fig_l2, axes_l2 = plt.subplots(1, 2, figsize=(18, 11))\n",
    "\n",
    "_top_n_l2 = 35\n",
    "_sp_top   = univariate_df.head(_top_n_l2)\n",
    "_c_sp     = [\"#E45756\" if v < 0 else \"#4C78A8\" for v in _sp_top[\"spearman\"]]\n",
    "axes_l2[0].barh(_sp_top[\"feature\"][::-1], _sp_top[\"spearman\"][::-1], color=_c_sp[::-1])\n",
    "axes_l2[0].axvline(0, color=\"black\", lw=0.5)\n",
    "axes_l2[0].axvline( 0.1, color=\"green\",  ls=\"--\", alpha=0.4, label=\"|r|=0.1\")\n",
    "axes_l2[0].axvline(-0.1, color=\"green\",  ls=\"--\", alpha=0.4)\n",
    "axes_l2[0].set_xlabel(\"Spearman 逶ｸ髢｢菫よ焚  (髱・豁｣, 襍､=雋)\")\n",
    "axes_l2[0].set_title(f\"竭｡ Spearman 逶ｸ髢｢  |r| TOP {_top_n_l2}\")\n",
    "axes_l2[0].legend(fontsize=8)\n",
    "\n",
    "_mi_top = univariate_df.nlargest(_top_n_l2, \"MI\")\n",
    "axes_l2[1].barh(_mi_top[\"feature\"][::-1], _mi_top[\"MI\"][::-1], color=\"#54A24B\")\n",
    "axes_l2[1].set_xlabel(\"Mutual Information\")\n",
    "axes_l2[1].set_title(f\"竭｡ Mutual Information  TOP {_top_n_l2}\")\n",
    "\n",
    "plt.suptitle(\"竭｡ 蜊伜､蛾㍼蛻・梵  (Spearman + Mutual Information  竊・ 騾溷ｺｦ蛛丞ｷｮ)\", fontsize=14, y=1.01)\n",
    "plt.tight_layout(); plt.show()\n",
    "\n",
    "# 笏笏 邨ｱ險医し繝槭Μ繝ｼ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "print(f\"\\n縲心pearman |r| 蛻・ｸ・曾")\n",
    "for _thr in (0.15, 0.10, 0.05, 0.02, 0.01):\n",
    "    _cnt = (univariate_df[\"spearman_abs\"] >= _thr).sum()\n",
    "    print(f\"  |r| 竕･ {_thr:.2f}: {_cnt:3d} 蛻予")\n",
    "print(f\"  |r| < 0.01 (縺ｻ縺ｼ辟｡逶ｸ髢｢): {(univariate_df['spearman_abs'] < 0.01).sum()} 蛻予")\n",
    "\n",
    "print(f\"\\n笨・univariate_df 讒狗ｯ牙ｮ御ｺ・({len(univariate_df)} 蛻・\")"
   ]
