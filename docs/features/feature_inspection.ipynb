    "    except Exception:\n",
    "        pass\n",
    "\n",
    "# 笏笏 竭｢ 繧ｨ繝ｳ繝峨・繧､繝ｳ繝・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "LLM_API_BASE = \"http://localhost:11434/v1\"\n",
    "LLM_API_KEY  = \"ollama\"\n",
    "\n",
    "# 笏笏 竭｣ 蛻・梵蜀・ｮｹ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "LLM_ANALYSIS_ITEMS = {\n",
    "    \"feature_ranking\":    True,\n",
