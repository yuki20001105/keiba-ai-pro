    "print(f\"{'='*65}\")\n",
    "print(f\"縲絶即 譛邨りｩ穂ｾ｡繧ｵ繝槭Μ繝ｼ縲・ total_score = 繝｢繝・Ν驥崎ｦ∝ｺｦﾃ・.4 + 蜊伜､蛾㍼ﾃ・.2 + MIﾃ・.1 + 繝・・繧ｿ蜩∬ｳｪﾃ・.3\")\n",
    "print(f\"{'='*65}\")\n",
    "_rc = {r: (_final[\"rank\"]==r).sum() for r in [\"S\",\"A\",\"B\",\"C\"]}\n",
    "print(f\"  S 繝ｩ繝ｳ繧ｯ (竕･0.65): {_rc['S']:3d} 蛻・ 竊・譛驥崎ｦ・ 蜑企勁縺吶ｋ縺ｨ繝｢繝・Ν邊ｾ蠎ｦ縺悟､ｧ縺阪￥菴惹ｸ欺")\n",
    "print(f\"  A 繝ｩ繝ｳ繧ｯ (竕･0.45): {_rc['A']:3d} 蛻・ 竊・驥崎ｦ・ 菫晄戟謗ｨ螂ｨ\")\n",
    "print(f\"  B 繝ｩ繝ｳ繧ｯ (竕･0.25): {_rc['B']:3d} 蛻・ 竊・荳ｭ遞句ｺｦ: 迥ｶ豕∵ｬ｡隨ｬ縺ｧ蜑企勁讀懆ｨ蚕")\n",
    "print(f\"  C 繝ｩ繝ｳ繧ｯ (< 0.25): {_rc['C']:3d} 蛻・ 竊・菴主ｯ・ｸ・ 蜑企勁蛟呵｣彌")\n",
    "print()\n",
    "_oc = _final[\"驕狗畑蛻・｡杤"].value_counts()\n",
    "for _op in [\"蠢・・",\"謗ｨ螂ｨ\",\"菫晄戟讀懆ｨ蚕",\"蜑企勁蛟呵｣彌",\"蜑企勁蛟呵｣・鬮朗aN)\",\"蜑企勁蛟呵｣・繝ｪ繝ｼ繧ｯ)\"]:\n",
    "    if _op in _oc: print(f\"  {_op:16s}: {_oc[_op]:3d} 蛻予")\n",
