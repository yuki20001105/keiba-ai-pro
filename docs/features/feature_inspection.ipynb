   "source": [
    "## 笏笏 繧ｻ繝ｫ 12: 谺謳榊､譁ｭ謐ｨ髮｢繝ｬ繝昴・繝・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "\n",
    "# 笏笏 谺謳榊次蝗繝ｻ謗ｨ螂ｨ繧｢繧ｯ繧ｷ繝ｧ繝ｳ縺ｮ蛻・｡槭Ν繝ｼ繝ｫ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "# 蜆ｪ蜈亥ｺｦ: 鬮・莉翫☆縺仙ｯｾ蜃ｦ / 荳ｭ=谺｡繧､繝・Ξ繝ｼ繧ｷ繝ｧ繝ｳ / 菴・蠕悟屓縺怜庄 / -=蟇ｾ蜃ｦ荳崎ｦ―n",
    "\n",
    "def _classify(col: str, nan_pct: float) -> tuple:\n",
    "    \"\"\"(谺謳榊次蝗, 謗ｨ螂ｨ繧｢繧ｯ繧ｷ繝ｧ繝ｳ, 蜆ｪ蜈亥ｺｦ) 繧定ｿ斐☆\"\"\"\n",
    "    c = col\n",
    "\n",
    "    # 笏笏 谺謳阪ヵ繝ｩ繧ｰ蛻暦ｼ・/1 縺ｪ縺ｮ縺ｫ NaN 縺ｯ逡ｰ蟶ｸ・俄楳笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "    if c.endswith(\"_is_missing\"):\n",
    "        return (\"谺謳阪ヵ繝ｩ繧ｰ蛻励′NaN\", \"蜑榊・逅・ fillna(0)\", \"鬮禄") if nan_pct > 5 \\\n",
    "               else (\"谺謳阪ヵ繝ｩ繧ｰ豁｣蟶ｸ\", \"縺昴・縺ｾ縺ｾ\", \"-\")\n",
    "\n",
    "    # 笏笏 繝ｩ繝・・繝ｻ繝壹・繧ｹ・域立繝・・繧ｿ蠖｢蠑上〒谺關ｽ・俄楳笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "    if c.startswith((\"lap_\", \"race_pace_\")):\n",
    "        if nan_pct > 70:\n",
    "            return (\"繧ｹ繧ｯ繝ｬ繧､繝玲悴蜿朱寔\\n譌ｧ繝・・繧ｿ蠖｢蠑乗ｬ關ｽ\", \"蜑企勁謗ｨ螂ｨ\\n(鬮朗aN譛滄俣)\", \"鬮禄")\n",
    "        return (\"繧ｹ繧ｯ繝ｬ繧､繝玲悴蜿朱寔\", \"蜀阪せ繧ｯ繝ｬ繧､繝励〒謾ｹ蝟Ы", \"荳ｭ\")\n",
    "\n",
    "    # 笏笏 謖√■繧ｿ繧､繝・・ust譎る俣繝・・繝悶Ν・俄楳笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "    if c.startswith(\"holding_\") or c == \"has_just_data\":\n",
    "        if nan_pct > 60:\n",
    "            return (\"繧ｹ繧ｯ繝ｬ繧､繝玲悴蜿朱寔\\n(just譎る俣繝・・繝悶Ν)\", \"蜑企勁謗ｨ螂ｨ or\\n2019蟷ｴ莉･髯埼剞螳喀", \"鬮禄")\n",
    "        return (\"繧ｹ繧ｯ繝ｬ繧､繝玲悴蜿朱寔\", \"蜀阪せ繧ｯ繝ｬ繧､繝励〒謾ｹ蝟Ы", \"荳ｭ\")\n",
    "\n",
    "    # 笏笏 騾溷ｺｦ謖・焚繝・・繝悶Ν・・f_*・俄楳笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "    if c.startswith(\"sf_\"):\n",
    "        if nan_pct > 60:\n",
    "            return (\"繧ｹ繧ｯ繝ｬ繧､繝玲悴蜿朱寔\\n(騾溷ｺｦ謖・焚繝・・繝悶Ν)\", \"蜑企勁謗ｨ螂ｨ or\\n2019蟷ｴ莉･髯埼剞螳喀", \"鬮禄")\n",
    "        return (\"繧ｹ繧ｯ繝ｬ繧､繝玲悴蜿朱寔\", \"蜀阪せ繧ｯ繝ｬ繧､繝励〒謾ｹ蝟Ы", \"荳ｭ\")\n",
    "\n",
    "    # 笏笏 隱ｿ謨吶ョ繝ｼ繧ｿ笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "    if c.startswith((\"last_training_\", \"training_\")) or c == \"has_training_data\":\n",
    "        return (\"繧ｹ繧ｯ繝ｬ繧､繝玲悴蜿朱寔\\n(隱ｿ謨吶ョ繝ｼ繧ｿ)\", \"蜑企勁謗ｨ螂ｨ or 蜀阪せ繧ｯ繝ｬ繧､繝予", \"荳ｭ\")\n",
    "\n",
    "    # 笏笏 繧ｳ繝ｼ繝翫・菴咲ｽｮ繝ｻ閼夊ｳｪ・医Ξ繝ｼ繧ｹ邨先棡繝壹・繧ｸ萓晏ｭ假ｼ俄楳笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "    if c in (\"corner_first\", \"corner_last\", \"corner_gain\", \"running_style_code\",\n",
    "             \"running_style_num\"):\n",
    "        return (\"繧ｹ繧ｯ繝ｬ繧､繝鈴Κ蛻・ｬ謳構\n(繧ｳ繝ｼ繝翫・菴咲ｽｮ)\", \"蜑榊・逅・ 譛鬆ｻ蛟､陬懷ｮ・or 蜑企勁\", \"荳ｭ\")\n",
    "\n",
    "    # 笏笏 蜑崎ｵｰ繝ｻ霑題ｵｰ邉ｻ・亥・襍ｰ=讒矩逧・ｬ謳搾ｼ俄楳笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "    structural_prefixes = (\n",
    "        \"prev_\", \"prev2_\", \"days_since_last_race\",\n",
    "        \"distance_change\", \"distance_increased\", \"distance_decreased\",\n",
    "        \"speed_index_change\", \"speed_avg_\", \"speed_best_\", \"speed_trend_\",\n",
    "        \"speed_improving\",\n",
    "        \"recent_form_\", \"form_\", \"win_count_\", \"top3_count_\",\n",
    "        \"running_style_mean_\", \"running_style_std_\",\n",
    "        \"is_class_up\", \"is_class_down\", \"is_same_class\", \"class_diff_abs\",\n",
    "        \"class_change\", \"prev_race_class_num\",\n",
    "    )\n",
    "    if c.startswith(structural_prefixes) or c in structural_prefixes:\n",
    "        return (\"讒矩逧・ｬ謳構\n(蛻晁ｵｰ=蜑崎ｵｰ縺ｪ縺・\", \"縺昴・縺ｾ縺ｾ\\n(谺謳阪ヵ繝ｩ繧ｰ蟇ｾ蠢懈ｸ・\", \"-\")\n",
    "\n",
    "    # 笏笏 騾夂ｮ玲・邵ｾ・・xpanding window縲∝・襍ｰ縺ｧ0莉ｶ・俄楳笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "    if c.startswith((\"horse_win_rate\", \"horse_show_rate\", \"horse_avg_\",\n",
    "                      \"horse_surface_\", \"horse_distance_\", \"horse_venue_\",\n",
    "                      \"horse_recent\", \"horse_speed_exp\")):\n",
    "        return (\"讒矩逧・ｬ謳構\n(蛻晏・蝣ｴ=螻･豁ｴ縺ｪ縺・\", \"繝吶う繧ｺ蟷ｳ貊大喧 or 0陬懷ｮ圭", \"菴蚕")\n",
    "\n",
    "    # 笏笏 鬨取焔繝ｻ隱ｿ謨吝ｸｫ邨ｱ險遺楳笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "    if c.startswith((\"jockey_\", \"trainer_\")):\n",
    "        if nan_pct > 30:\n",
    "            return (\"邨ｱ險郁ｨ育ｮ嶺ｸ崎ｶｳ\\n(蛻晏・蝣ｴ鬨取焔螟・\", \"繝吶う繧ｺ蟷ｳ貊大喧 / 蜈ｨ菴灘ｹｳ蝮・｣懷ｮ圭", \"荳ｭ\")\n",
    "        return (\"邨ｱ險郁ｨ育ｮ嶺ｸ崎ｶｳ\\n(蛻晏・蝣ｴ)\", \"縺昴・縺ｾ縺ｾ or 陬懷ｮ圭", \"菴蚕")\n",
    "\n",
    "    # 笏笏 辷ｶ鬥ｬ繝ｻ豈咲宛邨ｱ險遺楳笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "    if c.startswith((\"sire_\", \"damsire_\")):\n",
    "        return (\"邨ｱ險郁ｨ育ｮ嶺ｸ崎ｶｳ\\n(辷ｶ鬥ｬ繝・・繧ｿ荳崎ｶｳ)\", \"繝吶う繧ｺ蟷ｳ貊大喧 / 蜈ｨ菴灘ｹｳ蝮・｣懷ｮ圭", \"菴蚕")\n",
    "\n",
    "    # 笏笏 繧ｪ繝・ぜ繝ｻ莠ｺ豌礼ｳｻ笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "    if c in (\"odds\", \"popularity\", \"implied_prob\", \"log_odds\", \"odds_z_in_race\",\n",
    "             \"market_entropy\", \"top3_probability\", \"popularity_normalized\",\n",
    "             \"implied_prob_norm\", \"odds_rank_in_race\", \"log_odds\"):\n",
    "        if nan_pct > 20:\n",
    "            return (\"繧ｹ繧ｯ繝ｬ繧､繝玲ｬ謳構\n(繧ｪ繝・ぜ譛ｪ蜿朱寔)\", \"蜀阪せ繧ｯ繝ｬ繧､繝・or 蜑企勁\", \"鬮禄")\n",
    "        return (\"繧ｹ繧ｯ繝ｬ繧､繝鈴Κ蛻・ｬ謳構", \"蜑榊・逅・ 荳ｭ螟ｮ蛟､陬懷ｮ圭", \"菴蚕")\n",
    "\n",
    "    # 笏笏 鬥ｬ菴馴㍾笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "    if \"horse_weight\" in c or c == \"weight_vs_standard\":\n",
    "        return (\"繧ｹ繧ｯ繝ｬ繧､繝鈴Κ蛻・ｬ謳構\n(鬥ｬ菴馴㍾譛ｪ蝣ｱ蜻・\", \"蜑榊・逅・ 蜑崎ｵｰ菴馴㍾縺ｧ陬懷ｮ圭", \"菴蚕")\n",
    "\n",
    "    # 笏笏 NaN 縺ｻ縺ｼ縺ｪ縺暦ｼ域ｭ｣蟶ｸ・俄楳笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "    if nan_pct < 2:\n",
    "        return (\"豁｣蟶ｸ (菴晒aN)\", \"縺昴・縺ｾ縺ｾ\", \"-\")\n",
    "\n",
    "    return (\"荳肴・ / 隕∫｢ｺ隱構", \"蛟句挨遒ｺ隱構", \"荳ｭ\")\n",
    "\n",
    "\n",
    "# 笏笏 蜈ｨ蛻励・蛻・｡槭ユ繝ｼ繝悶Ν繧剃ｽ懈・ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "# 繧ｰ繝ｫ繝ｼ繝怜錐繧帝・ｼ輔″繝槭ャ繝怜喧\n",
    "col_to_group = {}\n",
    "for grp, cols in FEATURE_GROUPS.items():\n",
    "    for c in cols:\n",
    "        col_to_group[c] = grp\n",
    "\n",
    "report_rows = []\n",
    "for col in sorted(df.columns):\n",
    "    nr = nan_rates.get(col, 0.0) * 100        # nan_rates 縺ｯ 0-1 繧ｹ繧ｱ繝ｼ繝ｫ\n",
    "    pre_nr = pre_nan_rates.get(col, None)\n",
    "    in_model = col in df_pre.columns\n",
    "\n",
    "    cause, action, priority = _classify(col, nr)\n",
    "    report_rows.append({\n",
    "        \"column\":       col,\n",
    "        \"group\":        col_to_group.get(col, \"(縺昴・莉・\"),\n",
    "        \"nan_%_before\": round(nr, 1),\n",
    "        \"nan_%_after\":  round(pre_nr * 100, 1) if (in_model and pre_nr is not None) else (\"窶能" if in_model else \"髯､螟暴"),\n",
    "        \"in_model\":     \"笨貼" if in_model else \"\",\n",
    "        \"谺謳榊次蝗\":     cause,\n",
    "        \"謗ｨ螂ｨ繧｢繧ｯ繧ｷ繝ｧ繝ｳ\": action,\n",
    "        \"蜆ｪ蜈亥ｺｦ\":       priority,\n",
    "    })\n",
    "\n",
    "report_df = pd.DataFrame(report_rows)\n",
    "\n",
    "# 蜆ｪ蜈亥ｺｦ縺ｧ繧ｽ繝ｼ繝茨ｼ磯ｫ倪・荳ｭ竊剃ｽ寂・-・噂n",
    "priority_order = {\"鬮禄": 0, \"荳ｭ\": 1, \"菴蚕": 2, \"-\": 3}\n",
    "report_df[\"_sort\"] = report_df[\"蜆ｪ蜈亥ｺｦ\"].map(priority_order)\n",
    "report_df = report_df.sort_values([\"_sort\", \"nan_%_before\"], ascending=[True, False]).drop(columns=\"_sort\")\n",
    "\n",
    "# 繧ｵ繝槭Μ繝ｼ\n",
