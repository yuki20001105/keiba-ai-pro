      " race_avg_prev_speed    4290.4618    0.0000     0.0351\n",
      "   speed_vs_race_avg   72517.6432    0.0000     0.0290\n",
      "        top3_count_5   26823.2646    0.0000     0.0259\n",
      "  prev_race_distance   18305.5463    0.0000     0.0239\n",
      "      class_diff_abs    8693.4842    0.0032     0.0237\n",
      "      class_rank_adj   13154.0519    0.0000     0.0235\n",
      "         win_count_5   34211.9417    0.0000     0.0229\n",
      " race_max_prev_speed    7741.9443    0.0000     0.0217\n",
      "  race_class_encoded   43176.7454    0.0000     0.0215\n",
