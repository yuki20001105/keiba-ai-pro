   "source": [
    "## 笏笏 Cell L1: 竭 繝・・繧ｿ蜩∬ｳｪ蛻・梵 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "# 谺謳咲紫繝ｻ繝ｦ繝九・繧ｯ謨ｰ繝ｻ逡ｰ蟶ｸ蛟､ (3ﾃ悠QR豕・繝ｻ繝ｪ繝ｼ繧ｯ蜿ｯ閭ｽ諤ｧ 繧定ｩ穂ｾ｡縺吶ｋ\n",
    "\n",
    "import warnings\n",
    "\n",
    "# 笏笏 NaN 邇・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "_l1_nan = X_nb[_feature_cols_nb].isna().mean().rename(\"nan_rate\")\n",
    "\n",
    "# 笏笏 繝ｦ繝九・繧ｯ謨ｰ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "_l1_uniq = X_nb[_feature_cols_nb].nunique().rename(\"nunique\")\n",
    "\n",
    "# 笏笏 螟悶ｌ蛟､邇・(3ﾃ悠QR, 繧ｵ繝ｳ繝励Ν 50K 陦後〒鬮倬溷喧) 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "_n_q1 = min(50_000, len(X_nb))\n",
    "_Xq   = X_nb[_feature_cols_nb].sample(n=_n_q1, random_state=42)\n",
    "\n",
    "def _iqr_outlier_rate(s):\n",
    "    s = s.dropna()\n",
    "    if len(s) < 10: return 0.0\n",
    "    q1, q3 = s.quantile(0.25), s.quantile(0.75)\n",
    "    iqr = q3 - q1\n",
    "    if iqr == 0:     return 0.0\n",
    "    return float(((s < q1 - 3 * iqr) | (s > q3 + 3 * iqr)).mean())\n",
    "\n",
    "_l1_out = _Xq.apply(_iqr_outlier_rate).rename(\"outlier_rate\")\n",
    "\n",
    "# 笏笏 繝ｪ繝ｼ繧ｯ蜿ｯ閭ｽ諤ｧ繝√ぉ繝・け 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "# FUTURE_FIELDS 縺ｨ縺ｮ荳閾ｴ = HIGH  / 逹鬆・・繧ｿ繧､繝邉ｻ繝ｯ繝ｼ繝牙性譛・= MEDIUM\n",
    "_leak_kw = (\"_finish\", \"_time_\", \"speed_deviation\", \"_rank\", \"payout\", \"return\")\n",
    "\n",
    "def _leak_check(col: str) -> str:\n",
    "    if col in FUTURE_FIELDS:             return \"HIGH\"\n",
    "    if any(k in col for k in _leak_kw): return \"MEDIUM\"\n",
    "    return \"LOW\"\n",
    "\n",
    "_l1_leak = pd.Series({c: _leak_check(c) for c in _feature_cols_nb}, name=\"leak_risk\")\n",
    "\n",
    "# 笏笏 quality_df 讒狗ｯ・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "quality_df = pd.DataFrame({\n",
    "    \"nan_rate\":     _l1_nan,\n",
    "    \"nunique\":      _l1_uniq,\n",
    "    \"outlier_rate\": _l1_out,\n",
    "    \"leak_risk\":    _l1_leak,\n",
    "}).reset_index().rename(columns={\"index\": \"feature\"})\n",
    "\n",
    "_action_map = report_df.set_index(\"column\")[\"謗ｨ螂ｨ繧｢繧ｯ繧ｷ繝ｧ繝ｳ\"].to_dict()\n",
    "quality_df[\"譁ｭ謐ｨ髮｢繧｢繧ｯ繧ｷ繝ｧ繝ｳ\"] = quality_df[\"feature\"].map(_action_map).fillna(\"菫晄戟\")\n",
    "\n",
    "# 笏笏 蜿ｯ隕門喧 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "fig_l1, axes_l1 = plt.subplots(1, 3, figsize=(19, 8))\n",
    "\n",
    "# 蟾ｦ: NaN邇・TOP 30\n",
    "_q_sorted = quality_df.sort_values(\"nan_rate\", ascending=False).head(30)\n",
    "_c_nan = [\"#E45756\" if r > 0.5 else \"#F58518\" if r > 0.2 else \"#4C78A8\"\n",
    "          for r in _q_sorted[\"nan_rate\"]]\n",
    "axes_l1[0].barh(_q_sorted[\"feature\"][::-1], _q_sorted[\"nan_rate\"][::-1] * 100,\n",
    "                color=_c_nan[::-1])\n",
    "axes_l1[0].axvline(50, color=\"red\",    ls=\"--\", alpha=0.5, label=\">50%\")\n",
    "axes_l1[0].axvline(20, color=\"orange\", ls=\"--\", alpha=0.5, label=\">20%\")\n",
    "axes_l1[0].set_xlabel(\"NaN 邇・(%)\")\n",
    "axes_l1[0].set_title(\"NaN 邇・TOP 30\")\n",
    "axes_l1[0].legend(fontsize=8)\n",
    "\n",
    "# 荳ｭ: NaN邇・・蟶・ヰ繝ｼ\n",
    "_bins_l1  = [0, 0.01, 0.05, 0.1, 0.2, 0.5, 1.01]\n",
    "_blabels  = [\"0%\", \"縲・%\", \"縲・%\", \"縲・0%\", \"縲・0%\", \"縲・0%\", \">50%\"]\n",
    "_bcols    = [\"#54A24B\",\"#54A24B\",\"#EECA3B\",\"#EECA3B\",\"#F58518\",\"#E45756\"]\n",
    "_bhist    = [\n",
    "    ((quality_df[\"nan_rate\"] >= _bins_l1[i]) & (quality_df[\"nan_rate\"] < _bins_l1[i+1])).sum()\n",
    "    for i in range(len(_bins_l1)-1)\n",
    "]\n",
    "axes_l1[1].bar(_blabels[1:], _bhist, color=_bcols)\n",
    "for i, v in enumerate(_bhist):\n",
    "    if v > 0: axes_l1[1].text(i, v + 0.1, str(v), ha=\"center\", fontsize=9)\n",
    "axes_l1[1].set_ylabel(\"迚ｹ蠕ｴ驥乗焚\")\n",
    "axes_l1[1].set_title(\"NaN 邇・・蟶ソ")\n",
    "\n",
    "# 蜿ｳ: 蜩∬ｳｪ繧ｵ繝槭Μ繝ｼ繝・・繝悶Ν\n",
    "axes_l1[2].axis(\"off\")\n",
    "_lk = quality_df[\"leak_risk\"].value_counts()\n",
    "_tbl_data_l1 = [\n",
    "    [\"邱冗音蠕ｴ驥乗焚\",          str(len(quality_df))],\n",
    "    [\"NaN = 0%\",           str((quality_df[\"nan_rate\"] == 0).sum())],\n",
    "    [\"NaN 1縲・0%\",         str(((quality_df[\"nan_rate\"]>0.01)&(quality_df[\"nan_rate\"]<=0.2)).sum())],\n",
    "    [\"NaN 20縲・0%\",        str(((quality_df[\"nan_rate\"]>0.2 )&(quality_df[\"nan_rate\"]<=0.5)).sum())],\n",
    "    [\"NaN > 50%\",          str((quality_df[\"nan_rate\"]>0.5).sum())],\n",
    "    [\"螟悶ｌ蛟､邇・> 1%\",      str((quality_df[\"outlier_rate\"]>0.01).sum())],\n",
    "    [\"繝ｪ繝ｼ繧ｯ HIGH\",         str(_lk.get(\"HIGH\", 0))],\n",
    "    [\"繝ｪ繝ｼ繧ｯ MEDIUM\",       str(_lk.get(\"MEDIUM\", 0))],\n",
    "    [\"繝ｪ繝ｼ繧ｯ LOW (螳牙・)\",   str(_lk.get(\"LOW\", 0))],\n",
    "]\n",
    "_tbl_l1 = axes_l1[2].table(cellText=_tbl_data_l1, colLabels=[\"鬆・岼\",\"莉ｶ謨ｰ\"],\n",
    "                             cellLoc=\"center\", loc=\"center\", colWidths=[0.6, 0.3])\n",
    "_tbl_l1.auto_set_font_size(False); _tbl_l1.set_fontsize(10); _tbl_l1.scale(1, 1.8)\n",
    "axes_l1[2].set_title(\"繝・・繧ｿ蜩∬ｳｪ繧ｵ繝槭Μ繝ｼ\")\n",
    "\n",
    "plt.suptitle(\"竭 繝・・繧ｿ蜩∬ｳｪ蛻・梵  (NaN邇・・螟悶ｌ蛟､繝ｻ繝ｪ繝ｼ繧ｯ蜿ｯ閭ｽ諤ｧ)\", fontsize=14, y=1.02)\n",
    "plt.tight_layout(); plt.show()\n",
    "\n",
    "# 笏笏 繝・く繧ｹ繝亥・蜉・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "print(\"縲侵aN邇・> 20% 迚ｹ蠕ｴ驥上曾")\n",
    "for _, r in quality_df[quality_df[\"nan_rate\"]>0.2].sort_values(\"nan_rate\",ascending=False).iterrows():\n",
    "    print(f\"  {r['feature']:45s}  NaN={r['nan_rate']*100:.1f}%  \"\n",
    "          f\"{r['譁ｭ謐ｨ髮｢繧｢繧ｯ繧ｷ繝ｧ繝ｳ'].replace(chr(10),' ')}\")\n",
    "print(f\"\\n縲舌Μ繝ｼ繧ｯ MEDIUM/HIGH 迚ｹ蠕ｴ驥上曾")\n",
    "for _, r in quality_df[quality_df[\"leak_risk\"]!=\"LOW\"].iterrows():\n",
    "    print(f\"  {r['feature']:45s}  {r['leak_risk']}\")\n",
    "print(f\"\\n笨・quality_df 讒狗ｯ牙ｮ御ｺ・({len(quality_df)} 蛻・\")"
