    "\n",
    "# 笏笏 驕狗畑蛻・｡・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "def _op_class(row):\n",
    "    if row[\"leak_risk\"] == \"HIGH\":                 return \"蜑企勁蛟呵｣・繝ｪ繝ｼ繧ｯ)\"\n",
    "    if row[\"譁ｭ謐ｨ髮｢繧｢繧ｯ繧ｷ繝ｧ繝ｳ\"].startswith(\"蜑企勁謗ｨ螂ｨ\"): return \"蜑企勁蛟呵｣・鬮朗aN)\"\n",
    "    if row[\"nan_rate\"] > 0.5 or row[\"rank\"] == \"C\": return \"蜑企勁蛟呵｣彌"\n",
    "    if row[\"rank\"] == \"S\" and row[\"nan_rate\"] < 0.05: return \"蠢・・"\n",
    "    if row[\"rank\"] in (\"S\",\"A\"):                    return \"謗ｨ螂ｨ\"\n",
    "    return \"菫晄戟讀懆ｨ蚕"\n",
    "\n",
    "_final[\"驕狗畑蛻・｡杤"] = _final.apply(_op_class, axis=1)\n",
