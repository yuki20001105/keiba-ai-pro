   "source": [
    "## 笏笏 Cell M2: LLM 險ｭ螳・+ 繝励Ο繝ｳ繝励ヨ逕滓・ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "import requests as _req2\n",
    "\n",
    "# 笏笏 竭 繝舌ャ繧ｯ繧ｨ繝ｳ繝蛾∈謚・笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "LLM_BACKEND = \"ollama\"     # \"ollama\" | \"openai\" | \"print\"\n",
    "\n",
    "# 笏笏 竭｡ 繝｢繝・Ν蜆ｪ蜈磯・ｽ・(荳翫°繧蛾・↓蛻ｩ逕ｨ蜿ｯ閭ｽ縺ｪ繧ゅ・繧定・蜍暮∈謚・ 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏\n",
    "_MODEL_PRIORITY = [\n",
    "    \"qwen3:14b\",   # 鬮伜刀雉ｪ (9GB)\n",
    "    \"qwen3:4b\",    # 霆ｽ驥上・鬮倬・(2.5GB)\n",
    "    \"qwen3:1.7b\",  # 雜・ｻｽ驥・(1GB)\n",
    "]\n",
    "LLM_MODEL = _MODEL_PRIORITY[0]\n",
    "\n",
    "if LLM_BACKEND == \"ollama\":\n",
    "    try:\n",
    "        _tags = _req2.get(\"http://localhost:11434/api/tags\", timeout=2).json()\n",
    "        _installed = [m[\"name\"] for m in _tags.get(\"models\", [])]\n",
    "        for _cand in _MODEL_PRIORITY:\n",
