{
  "name": "keiba-ai-pro",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:api": "python scraping_service_ultimate_fast.py",
    "dev:all": "concurrently --names \"NEXT,API\" -c \"cyan,magenta\" \"npm run dev\" \"npm run dev:api\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "up": "powershell -ExecutionPolicy Bypass -File ./scripts/start-all.ps1",
    "down": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-all.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report e2e-report"
  },
  "dependencies": {
    "@google-cloud/vision": "^4.1.0",
    "@google/generative-ai": "^0.1.3",
    "@stripe/stripe-js": "^2.4.0",
    "@supabase/auth-helpers-nextjs": "^0.9.0",
    "@supabase/supabase-js": "^2.39.3",
    "cheerio": "^1.0.0-rc.12",
    "date-fns": "^3.2.0",
    "lucide-react": "^0.312.0",
    "next": "^16.1.1",
    "openai": "^4.24.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^2.10.3",
    "stripe": "^14.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
