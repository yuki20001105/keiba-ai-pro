# =============================================================================
# .env.example — 環境変数テンプレート
# =============================================================================
# このファイルをコピーして .env を作成し、実際の値を設定してください。
#   cp .env.example .env
#
# ⚠️  .env ファイルは絶対にGitにコミットしないでください。
#      （.gitignore に既に追加されています）
# =============================================================================


# ── JRA IPAT 認証情報（自動投票機能に必要） ──────────────────────────────
# execute_vote.py / ipat_voter.py が使用する。
# 本番投票を行う場合のみ設定。ドライランは設定不要（ただし警告が出る）。

# 加入者番号（8桁の数字）
IPAT_INET_ID=00000000

# INET-ID（ユーザーID、半角英数字）
IPAT_USER_ID=xxxxxxxx

# パスワード（半角英数字・記号）
IPAT_PASSWORD=xxxxxxxx

# P-ARS 番号（4桁の数字）
IPAT_PARS=0000


# ── Supabase 接続情報（クラウドDB使用時） ────────────────────────────────
# Supabase を使用しない場合は空のままにしてください（ローカル DB のみ動作）。

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here


# ── JWT / 認証設定 ────────────────────────────────────────────────────────
# 本番環境では必ず強力なランダム文字列に変更してください。
# 生成例: python -c "import secrets; print(secrets.token_hex(32))"

JWT_SECRET_KEY=change-me-to-a-strong-random-secret-in-production


# ── FastAPI サーバー設定（オプション） ────────────────────────────────────
# PORT=8000

# ── スケジューラー制御 ────────────────────────────────────────────────────
# SCHEDULER_ENABLED=true   # falseにするとスクレイプ自動実行を無効化
