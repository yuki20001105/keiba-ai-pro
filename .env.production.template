# ===================================
# 本番環境用 環境変数テンプレート
# ===================================
# Vercel ダッシュボード > Settings > Environment Variables に貼り付ける

# ★ Supabase（既存の値をそのまま使う）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ★ FastAPI バックエンドURL（Render デプロイ後に発行されるURL）
NEXT_PUBLIC_API_URL=https://keiba-ai-api.onrender.com

# アプリURL（Vercel デプロイ後に発行されるURL）
NEXT_PUBLIC_APP_URL=https://keiba-ai-pro.vercel.app
