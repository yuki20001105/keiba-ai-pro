# ===================================
# 本番環境用 環境変数テンプレート
# ===================================
# Vercel ダッシュボード > Settings > Environment Variables に貼り付ける
# 値は例示です。実値・secret をリポジトリへコミットしないでください。
# Preview / Staging / Production は環境ごとに別々に登録し、未設定のまま
# localhost fallback へ流れるデプロイは不合格とします。

# ★ 実行環境と安全側デフォルト（必須）
APP_ENV=production
NETKEIBA_RACE_WRITE_ENABLED=false
ALLOW_STAGING_WRITE=false
PRED_LIMIT_ALLOW_FAIL_OPEN=false
SCHEDULER_ENABLED=false
PHASE3J_SAGA_RUNTIME_MODE=disabled
PHASE3J_REMOTE_EFFECTS_ENABLED=false
PHASE3J_WORKER_DISPATCH_ENABLED=false
PHASE3J_EXECUTION_UNLOCK_ENABLED=false

# ★ Supabase（既存の値をそのまま使う）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# server-only。実値はVercel/Railway等のsecret storeに登録する
SUPABASE_SERVICE_ROLE_KEY=

# ★ FastAPIバックエンドURL正本（Next.js server route用・必須）
# ML_API_URL: 汎用FastAPI endpoint
# SCRAPE_API_URL: scrape/profiling endpoint（同一サービスでも明示設定する）
ML_API_URL=https://api.example.com
SCRAPE_API_URL=https://api.example.com

# 互換用public fallback。server routeの正本ではなく、上記2変数と同一originにする。
NEXT_PUBLIC_API_URL=https://api.example.com

# 次の旧名は実装から参照されないため使用禁止:
# NEXT_PUBLIC_ML_API_URL
# NEXT_PUBLIC_SCRAPING_API_URL

# アプリURL（Vercel デプロイ後に発行されるURL）
NEXT_PUBLIC_APP_URL=https://keiba-ai-pro.vercel.app
